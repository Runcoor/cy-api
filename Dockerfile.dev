FROM golang:1.26.1-alpine AS builder
ENV GO111MODULE=on CGO_ENABLED=0

ARG TARGETOS
ARG TARGETARCH
ENV GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64}

WORKDIR /build

ADD go.mod go.sum ./
RUN go mod download

COPY . .

RUN mkdir -p web/dist \
    && echo '<!doctype html><html><head><title>dev</title></head><body>dev mode — use http://localhost:5173</body></html>' > web/dist/index.html

RUN go build -ldflags "-s -w -X 'github.com/QuantumNous/aggre-api/common.Version=$(cat VERSION)'" -o aggre-api

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates tzdata wget \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates

COPY --from=builder /build/aggre-api /
EXPOSE 3000
WORKDIR /data
ENTRYPOINT ["/aggre-api"]
